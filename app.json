{
  "expo": {
    "name": "Galac6 Parent",
    "slug": "galac6-parent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "galac6parent",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0D1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ekkhara.galac6parent"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0D1A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.ekkhara.galac6parent"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": ["expo-router"]
  }
}
